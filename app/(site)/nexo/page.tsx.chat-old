"use client";

import React, { useState, useRef, useEffect } from "react";
import Link from "next/link";
import { ArrowLeft, Send, Sparkles, Zap, ShieldCheck, Bot } from "lucide-react";

interface Message {
  role: "user" | "assistant";
  content: string;
}

export default function NexoChatPage() {
  const [messages, setMessages] = useState<Message[]>([
    {
      role: "assistant",
      content:
        "**Nexo online.** 🌀\n\nSou o assistente do ecossistema Marroc. Posso te contar sobre Live Psytrance, Higher HZ, Marroc Solutions, livros, rituais e o laboratório.\n\nQual é a sua intenção?",
    },
  ]);

  const [input, setInput] = useState("");
  const [loading, setLoading] = useState(false);
  const messagesEndRef = useRef<HTMLDivElement>(null);

  const chatContainerRef = useRef<HTMLDivElement>(null);

  // Sem useEffect de scroll - causa perda de foco do input.
  // O scroll é feito inline após adicionar a mensagem (ver handleSend).


  const handleSend = async (e?: React.FormEvent) => {
    e?.preventDefault();
    if (!input.trim() || loading) return;

    const userMsg = input.trim();
    setInput("");
    setLoading(true);

    // Adiciona msg do usuário
    setMessages((prev) => [...prev, { role: "user", content: userMsg }]);

    // Scroll INLINE (não em useEffect) - requestAnimationFrame não rouba foco
    requestAnimationFrame(() => {
      if (chatContainerRef.current) {
        chatContainerRef.current.scrollTop = chatContainerRef.current.scrollHeight;
      }
    });

    try {
      const response = await fetch("/api/nexo", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          message: userMsg,
          history: messages.map((m) => ({ role: m.role, content: m.content })),
        }),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || "Erro na transmissão");
      }

      // Formata markdown simples (negrito)
      const formatted = data.reply
        .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
        .replace(/\n/g, "<br />");

      setMessages((prev) => [...prev, { role: "assistant", content: formatted }]);

      // Scroll após resposta chegar
      requestAnimationFrame(() => {
        if (chatContainerRef.current) {
          chatContainerRef.current.scrollTop = chatContainerRef.current.scrollHeight;
        }
      });
    } catch (error) {
      console.error("Nexo Error:", error);
      setMessages((prev) => [
        ...prev,
        {
          role: "assistant",
          content:
            "⚠️ **Falha no sinal.** Tive uma interferência. Tenta de novo em alguns segundos.",
        },
      ]);
    } finally {
      setLoading(false);
    }
  };

  return (
    <main className="min-h-screen bg-[#0a0a0a] text-paper selection:bg-fuchsia-500 selection:text-white overflow-hidden flex flex-col relative font-sans">
      {/* Background */}
      <div className="absolute inset-0 pointer-events-none">
        <div className="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(192,38,211,0.2),rgba(0,0,0,0))]" />
        <div className="absolute top-0 left-0 w-full h-full bg-[url('/noise.png')] opacity-[0.04] mix-blend-overlay" />
      </div>

      {/* Header */}
      <header className="relative z-50 flex items-center justify-between px-4 py-3 md:px-6 md:py-4 border-b border-white/10 bg-black/40 backdrop-blur-md">
        <div className="flex items-center gap-3 md:gap-4">
          <Link
            href="/"
            className="group flex items-center gap-2 text-xs font-mono text-fuchsia-300 hover:text-white transition uppercase tracking-widest"
          >
            <ArrowLeft size={14} className="group-hover:-translate-x-1 transition-transform" />
            <span className="hidden md:inline">Nexus</span>
          </Link>
          <div className="h-4 w-px bg-white/20 hidden md:block" />
          <div className="flex items-center gap-2">
            <div className="relative w-2 h-2 rounded-full bg-fuchsia-500 animate-pulse"></div>
            <span className="text-[10px] md:text-xs font-mono text-white/80 tracking-widest uppercase">
              Nexo v1.0 <span className="text-white/30 hidden sm:inline">// KIMI_K2.5_CLOUD</span>
            </span>
          </div>
        </div>

        <div className="flex items-center gap-2 text-[10px] md:text-xs font-mono text-cyan-300 uppercase tracking-widest">
          <Bot size={14} />
          <span className="hidden sm:inline">Assistente do Ecossistema</span>
        </div>
      </header>

      {/* Chat Area */}
      <div ref={chatContainerRef} tabIndex={-1} className="flex-1 overflow-y-auto p-2 md:p-6 lg:px-24 xl:px-48 relative z-10 scrollbar-thin scrollbar-thumb-fuchsia-500/20 scrollbar-track-transparent focus:outline-none">
        <div className="space-y-4 md:space-y-6 pb-4">
          {messages.map((msg, idx) => (
            <div
              key={idx}
              className={`flex w-full ${msg.role === "user" ? "justify-end" : "justify-start"}`}
            >
              <div
                className={`
                  max-w-[90%] md:max-w-[70%] rounded-lg p-3 md:p-6 relative
                  ${
                    msg.role === "user"
                      ? "bg-fuchsia-500/10 border border-fuchsia-500/30 text-white rounded-tr-none"
                      : "bg-[#0a0a0a]/80 border border-cyan-500/20 text-gray-100 rounded-tl-none shadow-[0_0_30px_-10px_rgba(34,211,238,0.2)]"
                  }
                `}
              >
                {/* Role Indicator */}
                <div
                  className={`text-[10px] font-mono mb-2 uppercase tracking-widest flex items-center gap-2 ${
                    msg.role === "user" ? "text-fuchsia-300 justify-end" : "text-cyan-400 justify-start"
                  }`}
                >
                  {msg.role === "user" ? (
                    "Você"
                  ) : (
                    <>
                      <Sparkles size={10} /> Nexo
                    </>
                  )}
                </div>

                {/* Content */}
                <div
                  className="leading-relaxed font-light text-sm md:text-base"
                  dangerouslySetInnerHTML={{ __html: msg.content }}
                />
              </div>
            </div>
          ))}

          {loading && (
            <div className="flex w-full justify-start">
              <div className="bg-[#0a0a0a]/50 border border-cyan-500/20 rounded-lg p-3 md:p-4 rounded-tl-none flex items-center gap-2 text-cyan-400/70 text-xs font-mono animate-pulse">
                <Zap size={12} />
                <span className="hidden md:inline">[PROCESSANDO FREQUÊNCIA...]</span>
                <span className="md:hidden">PROCESSANDO...</span>
              </div>
            </div>
          )}
          <div ref={messagesEndRef} />
        </div>
      </div>

      {/* Input Area */}
      <div className="relative z-50 p-2 md:p-6 lg:px-24 xl:px-48 bg-black/80 backdrop-blur-lg border-t border-white/10">
        <form onSubmit={handleSend} className="relative flex items-end gap-2 md:gap-4">
          <div className="relative flex-1 group">
            <div className="absolute inset-0 bg-fuchsia-500/5 rounded-lg blur opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <input
              type="text"
              value={input}
              onChange={(e) => setInput(e.target.value)}
              placeholder={loading ? "Nexo processando..." : "Pergunte ao Nexo sobre o ecossistema Marroc..."}
              className={`w-full bg-[#050505] border text-white placeholder-white/30 rounded-lg py-3 px-4 md:py-4 md:px-6 focus:outline-none focus:ring-1 transition-all font-mono text-base shadow-inner cursor-text ${
                loading
                  ? "border-cyan-500/30 focus:border-cyan-500 focus:ring-cyan-500/30"
                  : "border-white/20 focus:border-fuchsia-500 focus:ring-fuchsia-500/50"
              }`}
            />
          </div>

          <button
            type="submit"
            disabled={!input.trim() || loading}
            className={`
              p-3 md:p-4 rounded-lg flex items-center justify-center transition-all duration-300 min-w-[3.5rem]
              ${
                !input.trim() || loading
                  ? "bg-white/5 text-white/20 cursor-not-allowed border border-transparent"
                  : "bg-fuchsia-500 text-white hover:bg-fuchsia-400 border border-fuchsia-500 hover:shadow-[0_0_20px_rgba(217,70,239,0.4)]"
              }
            `}
            title={loading ? "Aguarde a resposta do Nexo..." : "Enviar mensagem"}
          >
            <Send size={20} />
          </button>
        </form>
        <div className="text-center mt-2 hidden md:block">
          <span className="text-[10px] text-white/20 font-mono uppercase tracking-widest flex items-center justify-center gap-1">
            <ShieldCheck size={10} /> Qwen 2.5 Cloud // Escopo: Ecossistema Marroc
          </span>
        </div>
      </div>
    </main>
  );
}
